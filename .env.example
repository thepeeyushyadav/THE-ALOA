# Main Groq key (used by features 1, 2, agent_brain)
GROQ_API_KEY=your_groq_api_key_here

# Feature 0 dedicated Groq key (Voice-Vision Agent)
GROQ_API_KEY_F0=your_feature0_groq_key_here

# Gemini keys (used by features 4, 6, 9)
GEMINI_API_KEY_1=your_gemini_key_1_here
GEMINI_API_KEY_2=your_gemini_key_2_here

# Feature 5 dedicated Gemini keys (Exam Pilot — 3-key rotation)
GEMINI_API_KEY_F5_1=your_gemini_f5_key_1_here
GEMINI_API_KEY_F5_2=your_gemini_f5_key_2_here
GEMINI_API_KEY_F5_3=your_gemini_f5_key_3_here

# OpenRouter (used by features 6, 7, 8, 9)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AWS Bedrock (used by feature 7 — Cloud Healer)
BEDROCK_API_KEY=your_bedrock_api_key_here
